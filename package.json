{
  "name": "monitor-tools",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:css": "tailwindcss -i css/tailwind.src.css -o css/tailwind.css --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "prestart": "npm run build:css && node scripts/inject-local-env.mjs",
    "preserve": "npm run build:css && node scripts/inject-local-env.mjs",
    "start": "npx -y serve -p 3000 -s .",
    "serve": "npx -y serve -p 3000 -s .",
    "local-config": "node scripts/inject-local-env.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "exports": {
    ".": {
      "import": "./dist/dsl/index.js",
      "types": "./dist/dsl/index.d.ts"
    }
  }
}
